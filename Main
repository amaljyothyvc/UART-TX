module uart_rx (
  input  logic  [7:0]data_in,
   input  logic       clk,
   input  logic       rst_n,
  input logic start_valid,
  output logic busy,
  output logic tx
);
  parameter int  sys_clk=50_000_000;
  parameter int  baudrate=9600;
  parameter int  baudclk=sys_clk/baudrate;
  typedef enum logic [1:0] {
    IDLE,
    START,
    DATA,
    STOP
  } state_t;
  
  state_t current_state,next_state;
  
 logic [2:0]bitcounter;
  logic [$clog2(baudclk)-1:0] baudcounter;
  
logic [7:0] shift_reg;
 logic baudtick;
  
  always_ff @(posedge clk or negedge rst_n) begin
    if(!rst_n) begin
      current_state<=IDLE;
    end
    else begin
      current_state<=next_state;
    end
  end
 
  always_ff @(posedge clk or negedge rst_n) begin
    if(!rst_n) begin
      baudtick<=1'b0;
      baudcounter<=1'b0;
    end
    else begin
      if(baudcounter>=baudclk-1) begin
      baudtick<=1'b1;
      baudcounter<=1'b0;
    end
    else  begin
      baudcounter<=baudcounter+1;
      baudtick<=1'b0;
    end
    end
  end

  always_comb begin
    next_state=current_state;
    case(current_state)
    IDLE: begin
      if(start_valid && !busy)
        next_state=START;
    end
    START: begin
      if(baudtick)
        next_state=DATA;
    end
    DATA: begin
      if(bitcounter>=7 && baudtick) begin
        next_state=STOP;
      end
    end
    STOP: begin
      if(baudtick)
        next_state=IDLE;
    end
    endcase
  end

  always_ff @(posedge clk or negedge rst_n) begin
    if(!rst_n) begin
      bitcounter<=0;
      busy<=0;
      shift_reg<=0;
    end
    else begin
    case(current_state) 
      IDLE: begin
      busy<=0;
      bitcounter<=0;
      tx <= 1'b1;
      
      shift_reg<=0;
      end
      START: begin
        tx<=1'b0;
        busy<=1'b1;
        shift_reg <= data_in;
      end
      DATA: begin
        if (baudtick) begin
          tx <= shift_reg[0];
          shift_reg <= {1'b0, shift_reg[7:1]};
          bitcounter<=bitcounter+1;
        end
      end
      STOP: begin
        bitcounter<=0;
        tx<=1'b1;
        busy<=1'b0;
      end
    endcase
    end
  end
endmodule
